{
  "name": "exam-zh-gui",
  "version": "0.1.0",
  "description": "A desktop GUI editor for creating exam-zh based Chinese exam papers.",
  "main": "./out/main/index.js",
  "type": "module",
  "packageManager": "pnpm@11.11.0+sha512.4463f65fd80ed80d69bc1d4bf163ee94f605c7380fc318bb5b2ebe15f8cd12d49c51a4d59e951b401e764d3b6ca751cbf51bc50ed7001a6bcb4935e684c34882",
  "scripts": {
    "electron:ensure": "node scripts/ensure-electron.mjs",
    "electron:install": "install-electron --no",
    "predev": "node scripts/ensure-electron.mjs",
    "dev": "electron-vite dev",
    "build": "pnpm typecheck && electron-vite build",
    "prepreview": "node scripts/ensure-electron.mjs",
    "preview": "electron-vite preview",
    "package:mac": "pnpm build && electron-builder --mac dir --config electron-builder.config.mjs",
    "tectonic:install-bundled": "node scripts/install-bundled-tectonic.mjs",
    "tectonic:ctex-warning-probe": "node scripts/tectonic-ctex-warning-probe.mjs",
    "tectonic:font-probe": "node scripts/tectonic-font-probe.mjs",
    "tectonic:probe": "node scripts/probe-tectonic.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "lint": "eslint . --max-warnings=0",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "check": "pnpm typecheck && pnpm lint && pnpm format:check && pnpm test && pnpm build"
  },
  "keywords": [
    "exam-zh",
    "electron",
    "latex",
    "exam"
  ],
  "author": "",
  "license": "Apache-2.0",
  "dependencies": {
    "lucide-react": "^0.468.0",
    "mathjax": "^4.1.3",
    "pdfjs-dist": "^6.1.200",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^7.0.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "globals": "^16.0.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^7.0.0",
    "vitest": "^3.0.0"
  }
}
